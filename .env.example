# ---------------------------------------------------------------------------
# Jira Business-Critical Watcher - configuration
# Copy this file to ".env" and fill in the real values. Never commit ".env".
# ---------------------------------------------------------------------------

# --- Jira ------------------------------------------------------------------
JIRA_BASE_URL=https://aphinity.atlassian.net
# The Atlassian account email that owns the API token below
JIRA_EMAIL=you@yourcompany.com
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_atlassian_api_token

# Projects and priority that define a "business critical" case
JIRA_PROJECTS=CON,T3,CL
JIRA_PRIORITY=Business Critical

# --- Polling ---------------------------------------------------------------
# How often the scheduled task runs. Also used by the --loop demo mode.
POLL_INTERVAL_MINUTES=5
# How many days back to look for freshly-closed tickets when sending RCAs
CLOSED_LOOKBACK_DAYS=3
# Only email on comments written by real people (skip Automation / bots)
HUMAN_ONLY=true

# --- AI / LLM provider -----------------------------------------------------
# Active provider: groq (default) | openai | azure | anthropic.
# Swap providers by changing this one line once you have the relevant key below.
LLM_PROVIDER=groq
# Optional generic overrides. If set, these win over the provider-specific
# values below (handy for pointing any provider at a custom gateway).
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=
# Deterministic + bounded output (anti-hallucination / token control).
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=700
LLM_TIMEOUT_SECONDS=60

# Groq (OpenAI-compatible) - default provider
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# OpenAI / Azure (OpenAI-compatible) - ready for swap
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude) - ready for swap
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# --- Email (SMTP) ----------------------------------------------------------
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Jira BC Watcher <bc-watcher@yourcompany.com>
# Comma-separated stakeholder recipients. Used for RCAs and as the fallback for
# progress updates when no per-audience lists are configured below.
EMAIL_RECIPIENTS=stakeholder1@yourcompany.com,stakeholder2@yourcompany.com

# Recipient-tailored progress updates (Phase 2). Set any of these to send an
# audience-specific version of each update. Leave a list empty to skip that
# audience. If ALL four are empty, the single general update goes to
# EMAIL_RECIPIENTS above (backward compatible).
# EMAIL_RECIPIENTS_SUPPORT=support-lead@yourcompany.com
# EMAIL_RECIPIENTS_DEV=eng-team@yourcompany.com
# EMAIL_RECIPIENTS_MANAGER=delivery-manager@yourcompany.com
# EMAIL_RECIPIENTS_LEADERSHIP=head-of-ops@yourcompany.com

# --- Behaviour -------------------------------------------------------------
# When true, emails are printed to the console instead of being sent.
# Great for the first test run and for recording the demo without SMTP.
DRY_RUN=true
STATE_FILE=state.json
